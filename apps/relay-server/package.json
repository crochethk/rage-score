{
  "name": "relay-server",
  "version": "0.0.0",
  "description": "Message relaying server for rage-score's spectator mode.",
  "private": true,
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist .tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "@repo/shared": "*",
    "debug": "^4.4.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.0.10",
    "dotenv": "^17.2.3",
    "eslint": "^9.33.0",
    "rimraf": "^6.1.2",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
