{
  "name": "relay-server",
  "version": "0.0.0",
  "description": "Message relaying server for rage-score's spectator mode.",
  "private": true,
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/node": "^25.0.10",
    "eslint": "^9.33.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
