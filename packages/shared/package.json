{
  "name": "@repo/shared",
  "version": "0.0.0",
  "description": "Code shared between client and relay-server.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "development": "./src/*.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:lib": "tsc -b",
    "watch": "tsc -b --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist .tsbuildinfo"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.39.3",
    "rimraf": "^6.1.3",
    "socket.io": "^4.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0"
  }
}
