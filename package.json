{
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @repo/shared && npm run build --workspaces",
    "dev:web": "npm run dev --workspace=rage-score -- --host",
    "build:web": "npm run build --workspace=rage-score",
    "dev:server": "npm run dev --workspace=relay-server",
    "clean": "npm run clean --workspaces --if-present",
    "prepurge": "npm run clean",
    "purge": "rimraf node_modules"
  },
  "devDependencies": {
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "3.6.2",
    "rimraf": "^6.1.2"
  }
}
